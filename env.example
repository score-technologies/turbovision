
# =============================================================================
# TURBOVISION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# =============================================================================
# 🔑 REQUIRED FOR ALL VALIDATORS AND MINERS
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────
# 💰 Bittensor Wallet Configuration
# ──────────────────────────────────────────────────────────────────────────
BITTENSOR_WALLET_COLD=default
BITTENSOR_WALLET_HOT=default
# BITTENSOR_WALLET_PATH=~/.bittensor/wallets  # Optional: Override wallet path
SCOREVISION_NETUID=423
BITTENSOR_SUBTENSOR_ENDPOINT=test
BITTENSOR_SUBTENSOR_FALLBACK=wss://test.finney.opentensor.ai:443

# =============================================================================
# ⛏️ OPEN SOURCE MINER
# =============================================================================

# Chutes config
CHUTES_API_KEY=cpk_xx.x.x
CHUTES_USERNAME=xx

# Huggingface config
HF_USER=Your_hf_user
HF_TOKEN=hf_xxx

# =============================================================================
# ⛏️ PRIVATE TRACK MINER
# =============================================================================

MINER_PORT=8000

# GHCR - miners use their own private container package
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-pat  # PAT with write:packages scope
GHCR_REPO=pt-solution  # Your package name (default: pt-solution)

# Fiber security
SUBTENSOR_NETWORK=finney
MIN_STAKE_THRESHOLD=1000

# Security toggles (default: true)
BLACKLIST_ENABLED=true
VERIFY_ENABLED=true

# =============================================================================
# VALIDATORS ONLY - ADDITIONAL CONFIGURATION
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────
# ☁️  Cloudflare R2 Storage
# ──────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=xxx
R2_WRITE_ACCESS_KEY_ID=xxx
R2_WRITE_SECRET_ACCESS_KEY=xxx
R2_BUCKET="xxx"
R2_BUCKET_PUBLIC_URL=https://pub-xxx.r2.dev
SCOREVISION_RESULTS_PREFIX=results_soccer
AUDIT_R2_RESULTS_PREFIX=audit_spotcheck
AUDIT_COMMIT_VALIDATOR_ON_START=1

# Public compliance checker (dedicated R2 + scheduling)
SCOREVISION_WINNERS_INDEX_URL=https://turbo.scoredata.me/manako/winners/index.json
CHECKER_R2_BUCKET=
CHECKER_R2_ACCOUNT_ID=
CHECKER_R2_WRITE_ACCESS_KEY_ID=
CHECKER_R2_WRITE_SECRET_ACCESS_KEY=
CHECKER_R2_BUCKET_PUBLIC_URL=
CHECKER_R2_RESULTS_PREFIX=manako/compliance
CHECKER_R2_FAILS_KEY=
CHECKER_INTERVAL_BLOCKS=3600
CHECKER_POLL_INTERVAL_S=60
CHECKER_CHALLENGES_PER_TARGET=10
CHECKER_IOU_MATCH_THRESHOLD=0.85
CHECKER_LATENCY_P95_MS=100
CHECKER_MAX_MODEL_BYTES=31457280
CHECKER_RUNTIME_MEMORY_BYTES=8589934592
CHECKER_RUNTIME_CPU_SECONDS=30
CHECKER_RUNTIME_WALL_TIMEOUT_S=45
CHECKER_SECURITY_FILE=
CHECKER_SECURITY_MODULE=

# ──────────────────────────────────────────────────────────────────────────
# ⚙️  ScoreVision Performance Tuning
# ──────────────────────────────────────────────────────────────────────────
SCOREVISION_SLO_MS=1000
SCOREVISION_BETA=0.002
SCOREVISION_ALPHA=1.0

# ──────────────────────────────────────────────────────────────────────────
# 📹 Video Processing Configuration
# ──────────────────────────────────────────────────────────────────────────
SCOREVISION_FRAMES=32
SCOREVISION_RES=960x540
SCOREVISION_TEMPO=150

# ──────────────────────────────────────────────────────────────────────────
# 💾 Cache & API Configuration
# ──────────────────────────────────────────────────────────────────────────
SCOREVISION_CACHE_DIR=~/.cache/scorevision/blocks
SV_TAIL=20000
SCOREVISION_API="https://api.scorevision.io"

# ──────────────────────────────────────────────────────────────────────────
# 🔄 Concurrency Settings
# ──────────────────────────────────────────────────────────────────────────
SCOREVISION_HTTP_CONCURRENCY=16
SCOREVISION_R2_CONCURRENCY=8
SCOREVISION_UPLOAD_CONCURRENCY=2

# ──────────────────────────────────────────────────────────────────────────
# ✍️  Signer Service Configuration
# ──────────────────────────────────────────────────────────────────────────
SIGNER_URL=http://signer:8080
SIGNER_HOST=0.0.0.0
SIGNER_PORT=8080
SIGNER_RETRIES=10
SIGNER_RETRY_DELAY=2

# ──────────────────────────────────────────────────────────────────────────
# 🔒 Private Track Validator
# ──────────────────────────────────────────────────────────────────────────
PRIVATE_MINER_TIMEOUT_S=30
PRIVATE_RESPONSES_R2_BUCKET=
PRIVATE_RESPONSES_R2_ACCOUNT_ID=
PRIVATE_RESPONSES_R2_WRITE_ACCESS_KEY_ID=
PRIVATE_RESPONSES_R2_WRITE_SECRET_ACCESS_KEY=
PRIVATE_RESPONSES_R2_PREFIX=private_responses
